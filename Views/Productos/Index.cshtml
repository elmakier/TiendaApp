@model IEnumerable<TiendaApp.Models.Producto>

@{
    ViewData["Title"] = "Lista de Productos";
}

<h2>Lista de Productos</h2>

<p>
    <a asp-action="Create" class="btn btn-primary">Nuevo Producto</a>
</p>

<table class="table">
    <thead>
        <tr>
            <th>Nombre</th>
            <th>Precio</th>
            <th>Stock</th>
            <th>Fecha de Vencimiento</th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model)
{
        <tr>
            <td>@item.Nombre</td>
            <td>@item.Precio</td>
            <td>@item.Stock</td>
            <td>@item.FechaVencimiento.ToShortDateString()</td>
        </tr>
}
    </tbody>
</table>